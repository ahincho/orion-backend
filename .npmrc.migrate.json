{
  "databaseUrl": "DATABASE_URL",
  "migrationsTable": "orion_migrations",
  "migrationsSchema": "public",
  "createSchema": true,
  "createMigrationsSchema": true,
  "schema": "public",
  "dir": "migrations",
  "ignorePattern": "\\..*",
  "useGlob": true,
  "singleTransaction": true,
  "decamelize": false,
  "pretty": true,
  "noLock": false,
  "advisoryLockMode": "fail"
}