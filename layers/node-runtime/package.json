{
  "name": "@orion/layer-node-runtime",
  "version": "0.0.0",
  "description": "ORION backend Lambda Layer: runtime npm dependencies (kysely, pg, jose, zod, middy, powertools). Built into a zip and mounted at /opt in every Lambda.",
