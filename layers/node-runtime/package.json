  "scripts": {
    "build": "bash build.sh"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.18.0",
    "@aws-lambda-powertools/tracer": "^2.18.0",
    "@aws-lambda-powertools/metrics": "^2.18.0",
    "@aws-sdk/client-eventbridge": "^3.717.0",
    "@aws-sdk/client-secrets-manager": "^3.717.0",
    "@aws-sdk/client-ssm": "^3.717.0",
    "@middy/core": "^7.7.0",
    "@middy/http-cors": "^7.7.0",
    "@middy/http-error-handler": "^7.7.0",
    "@middy/http-header-normalizer": "^7.7.0",
    "@middy/http-json-body-parser": "^7.7.0",
    "jose": "^6.2.3",
    "kysely": "^0.29.4",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  }
