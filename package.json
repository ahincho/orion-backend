{
  "name": "@orion/backend",
  "version": "0.0.0",
  "description": "ORION backend: serverless DDD+EDA monolith (Lambda + TypeScript + PostgreSQL).",
  "keywords": [
    "orion",
    "serverless",
    "aws-lambda",
    "typescript",
    "ddd",
    "eda",
    "postgres"
  ],
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.6.0",
  "workspaces": [
    "shared",
    "contexts/*",
    "layers/*"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace @orion/shared",
    "layer:build:all": "npm run build --workspace @orion/layer-node-shared && npm run build --workspace @orion/layer-node-runtime",
    "migrate:create": "node-pg-migrate create --use-glob --migration-file-language sql --migrations-table orion_migrations --create-schema --create-migrations-schema --migrations-schema public --schema public --single-transaction --ignore-pattern \"\\..*\"",
    "migrate:up": "node-pg-migrate up --use-glob --migrations-table orion_migrations --create-schema --create-migrations-schema --migrations-schema public --schema public --single-transaction --ignore-pattern \"\\..*\"",
    "migrate:down": "node-pg-migrate down --use-glob --migrations-table orion_migrations --migrations-schema public --schema public --single-transaction --ignore-pattern \"\\..*\"",
    "migrate:redo": "node-pg-migrate redo --use-glob --migrations-table orion_migrations --create-schema --create-migrations-schema --migrations-schema public --schema public --single-transaction --ignore-pattern \"\\..*\"",
    "migrate:status": "node-pg-migrate status --use-glob --migrations-table orion_migrations --migrations-schema public --schema public --ignore-pattern \"\\..*\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "format": "prettier --write --ignore-path .gitignore '**/*.{ts,mts,cts,mjs,cjs,js,json,md,yml,yaml}'",
    "format:check": "prettier --check --ignore-path .gitignore '**/*.{ts,mts,cts,mjs,cjs,js,json,md,yml,yaml}'",
    "local:api": "sam local start-api --warm-containers EAGER"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.152",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "node-pg-migrate": "^9.0.0",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.10"
  }
}
