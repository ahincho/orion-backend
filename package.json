{
  "name": "@orion/backend",
  "version": "0.0.0",
  "description": "ORION backend: serverless DDD+EDA monolith (Lambda + TypeScript + PostgreSQL).",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.6.0",
  "workspaces": [
    "shared",
    "contexts/*",
    "layers/*"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace @orion/shared",
    "layer:build:all": "npm run build --workspace @orion/layer-node-shared && npm run build --workspace @orion/layer-node-runtime",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.base.json && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "local:api": "sam local start-api --warm-containers EAGER"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.152",
    "@types/node": "^24.7.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
